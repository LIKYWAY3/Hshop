@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="hero">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Chi tiết sản phẩm</h1>
                    <p class="mb-4">Khám phá thông tin chi tiết và thêm sản phẩm yêu thích vào giỏ hàng của bạn.</p>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="hero-img-wrap">
                </div>
            </div>
        </div>
    </div>
</div>
<div class="untree_co-section">
    <div class="container">
        <div class="row" id="product-detail-container">
            <div class="col-12 text-center py-5">
                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem; color: #3b5d50 !important;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3 text-muted">Đang tải thông tin sản phẩm...</p>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        // Lấy ID từ Controller truyền sang (nếu bạn dùng ViewBag)
        // Hoặc bạn có thể lấy trực tiếp từ URL nếu cấu hình Route
        const productId = @(ViewBag.ProductId ?? "1"); // Mặc định là 1 để test

        document.addEventListener("DOMContentLoaded", function () {
            fetchProductDetail();
        });

        async function fetchProductDetail() {
            try {
                // Gọi API lấy dữ liệu của bạn
                const response = await fetch(`/api/products/${productId}`);

                if (!response.ok) {
                    throw new Error("Không tìm thấy sản phẩm này hoặc hệ thống đang bận.");
                }

                const product = await response.json();
                renderProduct(product);

            } catch (error) {
                document.getElementById('product-detail-container').innerHTML = `
                    <div class="col-12 text-center py-5">
                        <h3 class="text-danger">Lỗi!</h3>
                        <p>${error.message}</p>
                        <a href="/Shop" class="btn btn-secondary">Quay lại cửa hàng</a>
                    </div>`;
            }
        }

        function renderProduct(product) {
            // Sử dụng các class của UntreeStore template (btn-primary, text-primary, form-control...)
            const html = `
                <div class="col-12 col-md-6 mb-5 mb-md-0">
                    <div class="img-wrap" style="background: #dce5e4; border-radius: 20px; padding: 30px; text-align: center;">
                        <img src="${product.imageUrl || 'images/product-1.png'}"
                             alt="${product.productName}"
                             class="img-fluid"
                             style="max-height: 500px; object-fit: contain;">
                    </div>
                </div>

                <div class="col-12 col-md-6 pl-md-5">
                    <h2 class="section-title mb-3">${product.productName || 'Tên sản phẩm'}</h2>

                    <div class="mb-4">
                        <strong class="h2 text-primary d-block" style="color: #3b5d50 !important; font-weight: 700;">
                            $${product.price ? product.price.toFixed(2) : '0.00'}
                        </strong>
                    </div>

                    <p class="mb-4 text-muted" style="line-height: 1.8;">
                        ${product.description || 'Chưa có mô tả chi tiết cho sản phẩm này.'}
                    </p>

                    <div class="mb-5 d-flex align-items-center">
                        <div class="input-group" style="max-width: 150px;">
                            <button class="btn btn-outline-black decrease-btn" type="button" onclick="updateQty(-1)" style="border: 1px solid #ccc;">&minus;</button>
                            <input type="text" class="form-control text-center quantity-amount" id="quantity" value="1" readonly>
                            <button class="btn btn-outline-black increase-btn" type="button" onclick="updateQty(1)" style="border: 1px solid #ccc;">&plus;</button>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <button class="btn btn-primary" onclick="addToCart(${product.id})">Thêm vào giỏ hàng</button>
                        <a href="/Shop" class="btn btn-white-outline" style="border: 2px solid #2f2f2f; color: #2f2f2f;">Tiếp tục mua sắm</a>
                    </div>
                </div>
            `;

            document.getElementById('product-detail-container').innerHTML = html;
        }

        // Logic tăng/giảm số lượng
        function updateQty(amount) {
            const qtyInput = document.getElementById('quantity');
            let currentVal = parseInt(qtyInput.value);
            if (!isNaN(currentVal)) {
                let newVal = currentVal + amount;
                if (newVal < 1) newVal = 1;
                qtyInput.value = newVal;
            }
        }

        // Xử lý thêm vào giỏ hàng
        function addToCart(id) {
            const qty = document.getElementById('quantity').value;
            // Chỗ này sau này bạn sẽ gọi API Cart của nhóm bạn
            alert("Tuyệt vời! Đã thêm " + qty + " sản phẩm vào giỏ hàng.");
        }
    </script>
}