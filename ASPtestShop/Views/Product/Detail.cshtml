@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = "~/Views/Shared/_LayoutCustomer.cshtml";
}

<div class="container mt-5 mb-5" id="product-detail-container">
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h3 class="text-muted ms-3">Đang tải thông tin sản phẩm...</h3>
    </div>
</div>

@section Scripts {
    <script>
        // Lấy ID sản phẩm từ Controller C#
        const productId = parseInt('@ViewBag.ProductId') || 0;

        document.addEventListener("DOMContentLoaded", function () {
            loadProductDetail();
        });

        // Hàm dùng Fetch API để gọi dữ liệu (thay thế hoàn toàn cho Ajax jQuery)
        function loadProductDetail() {
            fetch(`/api/products/${productId}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error("Không tìm thấy sản phẩm hoặc ID không tồn tại.");
                    }
                    return response.json(); 
                })
                .then(product => {
                    renderProductUI(product);
                })
                .catch(error => {
                    // Xử lý khi lỗi (VD: gõ sai ID trên URL)
                    console.error("Lỗi:", error);
                    document.getElementById('product-detail-container').innerHTML = `
                        <div class="alert alert-danger text-center">
                            <h4>Oops! Rất tiếc...</h4>
                            <p>${error.message}</p>
                            <a href="/" class="btn btn-primary mt-2">Quay về trang chủ</a>
                        </div>
                    `;
                });
        }

        function renderProductUI(product) {
            console.log("Dữ liệu lấy từ API:", product);

            // Hàm format tiền tệ VNĐ
            const formattedPrice = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.price || 0);

            // Giao diện chi tiết sản phẩm
            const htmlContent = `
                <div class="row">
                    <!-- Cột Trái: Ảnh sản phẩm -->
                    <div class="col-md-5">
                        <img src="${product.imageUrl || '/images/no-image.png'}"
                             alt="${product.productName}"
                             class="img-fluid rounded shadow-sm"
                             style="width: 100%; object-fit: cover;">
                    </div>

                    <!-- Cột Phải: Thông tin chi tiết -->
                    <div class="col-md-7 mt-4 mt-md-0">
                        <nav aria-label="breadcrumb">
                          <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/" style="text-decoration: none; color: #555;">Trang chủ</a></li>
                            <li class="breadcrumb-item"><a href="#" style="text-decoration: none; color: #555;">Sản phẩm</a></li>
                            <li class="breadcrumb-item active" aria-current="page">${product.productName}</li>
                          </ol>
                        </nav>

                        <h1 class="display-6 fw-bold" style="color: #2b3a28;">${product.productName}</h1>

                        <h2 class="text-danger fw-bold mt-3">${formattedPrice}</h2>

                        <div class="mt-4">
                            <p class="text-muted">${product.description || 'Chưa có mô tả cho sản phẩm này.'}</p>
                        </div>

                        <!-- Phần chọn số lượng và thêm vào giỏ -->
                        <div class="d-flex align-items-center mt-4">
                            <label class="me-3 fw-bold">Số lượng:</label>
                            <input type="number" id="qty" class="form-control text-center me-3" value="1" min="1" max="99" style="width: 80px;">

                            <button class="btn btn-success btn-lg" onclick="addToCart(${product.id})" style="background-color: #3b5d49; border: none;">
                                <i class="fas fa-shopping-cart me-2"></i> Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('product-detail-container').innerHTML = htmlContent;
        }

        // Tạm thời tạo sẵn hàm Thêm giỏ hàng (sẽ code logic ở các bước sau)
        function addToCart(id) {
            const quantity = document.getElementById('qty').value;
            alert('Bạn vừa click thêm sản phẩm ID: ' + id + ' với số lượng: ' + quantity + ' vào giỏ hàng! (Chức năng này sẽ code sau)');
        }
    </script>
}