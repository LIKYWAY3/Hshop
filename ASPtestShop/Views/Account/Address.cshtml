@model ASPtestShop.Models.ViewModels.Profile.UserProfileViewModel

@{
    ViewData["Title"] = "Địa Chỉ Của Tôi";
}

@section Styles {
    <style>
        .address-page-wrapper .btn-address-primary {
            background-color: #3b5d50;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 2px;
            transition: 0.2s;
            font-weight: 500;
        }

            .address-page-wrapper .btn-address-primary:hover {
                background-color: #2c4c41;
                color: white;
            }

        .address-page-wrapper .badge-default {
            color: #3b5d50;
            border: 1px solid #3b5d50;
            padding: 2px 4px;
            font-size: 10px;
            border-radius: 2px;
            margin-top: 5px;
            display: inline-block;
        }

        .address-page-wrapper .action-link {
            color: #3b5d50;
            text-decoration: none;
            font-size: 14px;
            margin-left: 10px;
            cursor: pointer;
        }

            .address-page-wrapper .action-link:hover {
                text-decoration: underline;
                color: #2c4c41;
            }

        .address-page-wrapper .btn-set-default {
            background-color: white;
            border: 1px solid #ccc;
            color: #555;
            padding: 4px 12px;
            border-radius: 2px;
            font-size: 14px;
            margin-top: 10px;
        }

            .address-page-wrapper .btn-set-default:hover:not(:disabled) {
                background-color: #f8f9fa;
            }

            .address-page-wrapper .btn-set-default:disabled {
                border-color: #e8e8e8;
                color: #ccc;
                cursor: not-allowed;
            }

        .text-umi {
            color: #3b5d50 !important;
        }

        .avatar-50 {
            width: 50px;
            height: 50px;
            object-fit: cover;
        }

        .radius-2 {
            border-radius: 2px !important;
        }

        .text-title-md {
            font-size: 1.125rem;
        }

        .text-title-lg {
            font-size: 1.25rem;
        }

        .text-name {
            font-size: 16px;
        }

        .lh-15 {
            line-height: 1.5;
        }

        .checkbox-umi {
            accent-color: #3b5d50;
        }

        .btn-modal-cancel {
            padding: 8px 20px;
            border-radius: 2px;
        }

        .btn-modal-submit {
            padding: 8px 30px;
            border-radius: 2px;
        }
    </style>
}

<div class="untree_co-section profile-page-container address-page-wrapper mb-5 mt-4">
    <div class="container">
        <div class="row">

            <div class="col-md-3">
                <div class="sidebar-user-info d-flex align-items-center mb-4">
                    @if (string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="https://ui-avatars.com/api/?name=@Model.UserName&background=3b5d50&color=fff" alt="Avatar" class="sidebar-avatar me-3 rounded-circle avatar-50" />
                    }
                    else
                    {
                        <img src="@Model.AvatarUrl" alt="Avatar" class="sidebar-avatar me-3 rounded-circle avatar-50" />
                    }
                    <div>
                        <h6 class="mb-0 fw-bold">@Model.UserName</h6>
                        <a href="/account/profile" class="text-muted small text-decoration-none edit-profile-link text-umi">
                            <svg viewBox="0 0 24 24" class="icon-pencil"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="currentColor" /></svg> Sửa Hồ Sơ
                        </a>
                    </div>
                </div>

                <ul class="sidebar-menu list-unstyled">
                    <li class="menu-item active mb-2">
                        <a href="#" class="text-decoration-none text-dark fw-bold">
                            <svg viewBox="0 0 24 24" class="menu-icon text-primary"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor" /></svg> Tài Khoản Của Tôi
                        </a>
                        <ul class="sub-menu list-unstyled ms-4 mt-2">
                            <li><a asp-controller="Account" asp-action="Profile" class="active-text">Hồ Sơ</a></li>
                            <li><a asp-controller="Account" asp-action="Bank">Ngân Hàng</a></li>
                            <li><a asp-controller="Account" asp-action="Address">Địa Chỉ</a></li>
                            <li><a asp-controller="Account" asp-action="ChangePassword">Đổi Mật Khẩu</a></li>
                        </ul>
                    </li>
                    <li class="menu-item mb-2 mt-3">
                        <a href="#" class="text-decoration-none text-dark">
                            <svg viewBox="0 0 24 24" class="menu-icon text-info"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" fill="currentColor" /></svg> Đơn Mua
                        </a>
                    </li>
                    <li class="menu-item mt-3">
                        <a href="#">
                            <svg viewBox="0 0 24 24" class="menu-icon text-warning"><path d="M21 11.11V7c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v4.11C4.34 11.45 5 12.63 5 14s-.66 2.55-2 2.89V21c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-4.11c-1.34-.34-2-1.52-2-2.89s.66-2.55 2-2.89zM19 21H5v-2.09c1.92-.91 3-2.92 3-4.91s-1.08-4-3-4.91V7h14v2.09c-1.92.91-3 2.92-3 4.91s1.08 4 3 4.91V21zm-6-9h-2v2h2v-2zm0-4h-2v2h2V8zm0 8h-2v2h2v-2z" fill="currentColor" /></svg> Phiếu giảm giá
                        </a>
                    </li>
                </ul>
            </div>

            <div class="col-md-9">
                <div class="profile-card card border-0 bg-white shadow-sm radius-2">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success m-4 mb-0">@TempData["SuccessMessage"]</div>
                    }

                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                            <h5 class="mb-0 fw-normal text-title-md">Địa chỉ của tôi</h5>
                            <button class="btn-address-primary" data-bs-toggle="modal" data-bs-target="#addAddressModal">
                                <i class="fas fa-plus"></i> Thêm địa chỉ mới
                            </button>
                        </div>

                        <div class="address-list">
                            @{
                                var addressList = ViewBag.Addresses as List<ASPtestShop.Data.Entities.UserAddress>;
                            }

                            @if (addressList != null && addressList.Any())
                            {
                                foreach (var addr in addressList)
                                {
                                    <div class="row mb-3 pb-3 border-bottom align-items-start">
                                        <div class="col-md-9">
                                            <div class="d-flex align-items-center mb-1">
                                                <span class="fw-bold me-2 text-name">@addr.FullName</span>
                                                <span class="text-muted small border-start ps-2 border-secondary">@addr.PhoneNumber</span>
                                            </div>
                                            <div class="text-muted small mb-1 lh-15">
                                                @addr.SpecificAddress
                                            </div>

                                            @if (addr.IsDefault)
                                            {
                                                <span class="badge-default">Mặc định</span>
                                            }
                                        </div>

                                        <div class="col-md-3 text-end">
                                            <div>
                                                <a onclick="openEditModal(@addr.Id, '@addr.FullName', '@addr.PhoneNumber', '@addr.SpecificAddress', @addr.IsDefault.ToString().ToLower())" class="action-link">Cập nhật</a>

                                                @if (!addr.IsDefault)
                                                {
                                                    <a href="#" class="action-link text-danger">Xóa</a>
                                                }
                                            </div>
                                            <form action="/account/set-default-address/@addr.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-set-default" @(addr.IsDefault ? "disabled" : "")>
                                                    Thiết lập mặc định
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <div class="text-muted fs-5">Bạn chưa có địa chỉ nào.</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="addAddressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 radius-2">
            <div class="modal-header pb-2">
                <h5 class="modal-title text-title-lg">Địa chỉ mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/account/add-address" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <input type="text" name="FullName" class="form-control" required placeholder="Họ và tên">
                        </div>
                        <div class="col-md-6">
                            <input type="text" name="PhoneNumber" class="form-control" required placeholder="Số điện thoại">
                        </div>
                    </div>

                    <div class="mb-3">
                        <textarea name="SpecificAddress" class="form-control" rows="3" required placeholder="Tỉnh/Thành phố, Quận/Huyện, Phường/Xã, Tên đường, Tòa nhà, Số nhà..."></textarea>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input checkbox-umi" type="checkbox" name="IsDefault" value="true" id="defaultCheck">
                        <label class="form-check-label text-muted" for="defaultCheck">
                            Đặt làm địa chỉ mặc định
                        </label>
                    </div>

                </div>
                <div class="modal-footer border-0 pt-0 pb-4 pe-4">
                    <button type="button" class="btn btn-light btn-modal-cancel" data-bs-dismiss="modal">Trở lại</button>
                    <button type="submit" class="btn-address-primary btn-modal-submit">Hoàn thành</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editAddressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 radius-2">
            <div class="modal-header pb-2">
                <h5 class="modal-title text-title-lg">Cập nhật địa chỉ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/account/edit-address" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId" />

                <div class="modal-body p-4">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <input type="text" name="FullName" id="editFullName" class="form-control" required placeholder="Họ và tên">
                        </div>
                        <div class="col-md-6">
                            <input type="text" name="PhoneNumber" id="editPhone" class="form-control" required placeholder="Số điện thoại">
                        </div>
                    </div>
                    <div class="mb-3">
                        <textarea name="SpecificAddress" id="editSpecific" class="form-control" rows="3" required placeholder="Địa chỉ cụ thể..."></textarea>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input checkbox-umi" type="checkbox" name="IsDefault" value="true" id="editIsDefault">
                        <label class="form-check-label text-muted" for="editIsDefault">
                            Đặt làm địa chỉ mặc định
                        </label>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 pe-4">
                    <button type="button" class="btn btn-light btn-modal-cancel" data-bs-dismiss="modal">Trở lại</button>
                    <button type="submit" class="btn-address-primary btn-modal-submit">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditModal(id, name, phone, address, isDefault) {
            document.getElementById('editId').value = id;
            document.getElementById('editFullName').value = name;
            document.getElementById('editPhone').value = phone;
            document.getElementById('editSpecific').value = address;
            document.getElementById('editIsDefault').checked = isDefault;

            var editModal = new bootstrap.Modal(document.getElementById('editAddressModal'));
            editModal.show();
        }
    </script>
}