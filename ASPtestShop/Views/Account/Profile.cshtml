@model ASPtestShop.Models.ViewModels.Profile.UserProfileViewModel

@{
    ViewData["Title"] = "Hồ Sơ Của Tôi";
}

<div class="untree_co-section profile-page-container">
    <div class="container">
        <div class="row">
            
            <div class="col-md-3">
                <div class="sidebar-user-info d-flex align-items-center mb-4">
                    @if (string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="https://ui-avatars.com/api/?name=@Model.UserName&background=3b5d50&color=fff" alt="Avatar" class="sidebar-avatar me-3" />
                    }
                    else
                    {
                        <img src="@Model.AvatarUrl" alt="Avatar" class="sidebar-avatar me-3" />
                    }
                    <div>
                        <h6 class="mb-0 fw-bold">@Model.UserName</h6>
                        <a href="#" class="text-muted small text-decoration-none edit-profile-link">
                            <svg viewBox="0 0 24 24" class="icon-pencil"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="currentColor"/></svg> Sửa Hồ Sơ
                        </a>
                    </div>
                </div>

                <ul class="sidebar-menu list-unstyled">
                    <li class="menu-item active mb-2">
                        <a href="#">
                            <svg viewBox="0 0 24 24" class="menu-icon text-primary"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/></svg> Tài Khoản Của Tôi
                        </a>
                        <ul class="sub-menu list-unstyled ms-4 mt-2">
                            <li><a asp-controller="Account" asp-action="Profile" class="active-text">Hồ Sơ</a></li>
                            <li><a asp-controller="Account" asp-action="Bank">Ngân Hàng</a></li>
                            <li><a asp-controller="Account" asp-action="Address">Địa Chỉ</a></li>
                            <li><a asp-controller="Account" asp-action="ChangePassword">Đổi Mật Khẩu</a></li>
                        </ul>
                    </li>
                    <li class="menu-item mb-2 mt-3">
                        <a asp-controller="Order" asp-action="History" class="text-decoration-none text-dark">
                            <svg viewBox="0 0 24 24" class="menu-icon text-info"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" fill="currentColor" /></svg> Đơn Mua
                        </a>
                    </li>
                </ul>
            </div>

            <div class="col-md-9">
                <div class="profile-card card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom pt-4 pb-3 px-4">
                        <h5 class="mb-1 fw-bold">Hồ Sơ Của Tôi</h5>
                        <p class="text-muted small mb-0">Quản lý thông tin hồ sơ để bảo mật tài khoản</p>
                    </div>

                    <div class="card-body p-4">
                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                                <strong>Thành công!</strong> @TempData["SuccessMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <form asp-action="UpdateProfile" asp-controller="Account" method="post" enctype="multipart/form-data">
                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="AvatarUrl" /> 
                            <input type="hidden" asp-for="Email" />
                            <input type="hidden" asp-for="PhoneNumber" />
                            <input type="hidden" asp-for="UserName" />

                            <div class="row">
                                <div class="col-md-8 pe-md-4">
                                    
                                    <div class="row mb-3">
                                        <div class="col-md-3 text-md-end pt-2">
                                            <label class="form-label-custom mb-0">Tên đăng nhập</label>
                                        </div>
                                        <div class="col-md-9">
                                            <input asp-for="UserName" class="profile-form-control" readonly />
                                            <div class="small text-muted mt-1">Tên Đăng nhập chỉ có thể thay đổi một lần.</div>
                                        </div>
                                    </div>

                                    <div class="row mb-3 align-items-center">
                                        <div class="col-md-3 text-md-end">
                                            <label asp-for="FullName" class="form-label-custom mb-0">Tên</label>
                                        </div>
                                        <div class="col-md-9">
                                            <input asp-for="FullName" class="profile-form-control" placeholder="Nhập họ và tên" />
                                        </div>
                                    </div>

                                    <div class="row mb-3 align-items-center">
                                        <div class="col-md-3 text-md-end">
                                            <label class="form-label-custom mb-0">Email</label>
                                        </div>
                                        <div class="col-md-9 d-flex align-items-center">
                                            <span class="me-3 text-dark">@Model.MaskedEmail</span>
                                            <a asp-action="ChangeEmail" asp-controller="Account" class="text-decoration-none small profile-link-blue">Thay Đổi</a>
                                        </div>
                                    </div>

                                    <div class="row mb-3 align-items-center">
                                        <div class="col-md-3 text-md-end">
                                            <label class="form-label-custom mb-0">Số điện thoại</label>
                                        </div>
                                        <div class="col-md-9 d-flex align-items-center">
                                            <span class="me-3 text-dark">@Model.MaskedPhoneNumber</span>
                                            <a asp-action="ChangePhone" asp-controller="Account" class="text-decoration-none small profile-link-blue">Thay Đổi</a>
                                        </div>
                                    </div>

                                    <div class="row mb-3 align-items-center">
                                        <div class="col-md-3 text-md-end">
                                            <label class="form-label-custom mb-0">Giới tính</label>
                                        </div>
                                        <div class="col-md-9">
                                            <div class="d-flex align-items-center gap-4 pt-1">
                                                <div class="form-check mb-0">
                                                    <input class="form-check-input custom-radio-umi" type="radio" asp-for="Gender" value="Nam" id="genderMale">
                                                    <label class="form-check-label text-dark" for="genderMale">Nam</label>
                                                </div>
                                                <div class="form-check mb-0">
                                                    <input class="form-check-input custom-radio-umi" type="radio" asp-for="Gender" value="Nữ" id="genderFemale">
                                                    <label class="form-check-label text-dark" for="genderFemale">Nữ</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row mb-4 align-items-center">
                                        <div class="col-md-3 text-md-end">
                                            <label class="form-label-custom mb-0">Địa chỉ</label>
                                        </div>
                                        <div class="col-md-9 d-flex align-items-center">
                                            <span class="me-3 text-dark">@(string.IsNullOrEmpty(Model.Address) ? "Chưa thiết lập" : Model.Address)</span>

                                            <a href="/account/address" class="text-decoration-none small profile-link-blue">Thay Đổi</a>

                                            <input type="hidden" asp-for="Address" />
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-3"></div>
                                        <div class="col-md-9">
                                            <button type="submit" class="btn-save-profile">Lưu</button>
                                        </div>
                                    </div>

                                </div>

                                <div class="col-md-4 border-start text-center avatar-upload-section d-flex flex-column align-items-center pt-3">
                                    @if (string.IsNullOrEmpty(Model.AvatarUrl))
                                    {
                                        <img id="avatarPreview" src="https://ui-avatars.com/api/?name=@Model.UserName&background=3b5d50&color=fff&size=150" alt="Avatar" class="avatar-preview-lg" />
                                    }
                                    else
                                    {
                                        <img id="avatarPreview" src="@Model.AvatarUrl" alt="Avatar" class="avatar-preview-lg" />
                                    }

                                    <label asp-for="AvatarFile" class="btn-choose-image mt-3">Chọn Ảnh</label>
                                    <input asp-for="AvatarFile" type="file" class="d-none" accept="image/jpeg, image/png" onchange="previewImage(event)" />
                                    
                                    <div class="avatar-upload-hint mt-3">
                                        Dung lượng file tối đa 1 MB<br />
                                        Định dạng: .JPEG, .PNG
                                    </div>
                                </div>  
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function() {
                var output = document.getElementById('avatarPreview');
                output.src = reader.result;
            }
            if(event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
}