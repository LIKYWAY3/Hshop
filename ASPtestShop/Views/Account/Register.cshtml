@model ASPtestShop.Models.ViewModels.Auth.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<div class="container mt-5 register-container">
    <div class="card shadow-sm border-0">
        <div class="card-header text-center">
            <h4 class="mb-0">Đăng ký tài khoản</h4>
        </div>

        <div class="card-body p-4 p-md-5">
            <form asp-action="Register" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-4 font-weight-bold"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="UserName" class="form-label">Username <span class="text-danger">*</span></label>
                        <input asp-for="UserName" class="form-control" placeholder="Nhập username" />
                        <span asp-validation-for="UserName" class="text-danger d-block mt-1"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="form-label">Họ tên <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên" />
                        <span asp-validation-for="FullName" class="text-danger d-block mt-1"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                    <input asp-for="Email" class="form-control" placeholder="Nhập email" />
                    <span asp-validation-for="Email" class="text-danger d-block mt-1"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Địa chỉ</label>
                    <input asp-for="Address" class="form-control" placeholder="Có thể bỏ trống" />
                    <span asp-validation-for="Address" class="text-danger d-block mt-1"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                        <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu" />
                        <span asp-validation-for="Password" class="text-danger d-block mt-1"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">Nhập lại mật khẩu <span class="text-danger">*</span></label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger d-block mt-1"></span>
                    </div>
                </div>

                <button type="submit" class="btn w-100 register-btn mt-2">
                    Đăng ký tài khoản
                </button>

                <div class="text-center mt-4 register-links">
                    <p class="mb-0 text-muted">Đã có tài khoản? <a href="/account/login">Đăng nhập ngay</a></p>
                </div>
            </form>
        </div>
    </div>
</div>