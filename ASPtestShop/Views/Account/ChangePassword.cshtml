@model ASPtestShop.Models.ViewModels.Profile.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi Mật Khẩu";
}

@section Styles {
    <style>
        .form-label-custom {
            font-weight: 500;
            color: #333;
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }

        .form-control-custom {
            border-radius: 8px;
            padding: 0.8rem 1rem;
            border: 1px solid #dcdfe6;
            background-color: #fcfcfc;
            transition: all 0.3s ease;
        }

            .form-control-custom:focus {
                background-color: #ffffff;
                border-color: #315b4c;
                box-shadow: 0 0 0 3px rgba(49, 91, 76, 0.15);
                outline: none;
            }

        .btn-green-custom {
            background-color: #315b4c;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 0.8rem 2.5rem;
            font-weight: 500;
            transition: all 0.3s;
        }

            .btn-green-custom:hover {
                background-color: #234539;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(49, 91, 76, 0.25);
            }

        .text-error-custom {
            font-size: 0.85rem;
            color: #dc3545;
            margin-top: 0.4rem;
            display: block;
        }
    </style>
}

<div class="untree_co-section profile-page-container">
    <div class="container">
        <div class="row">

            <div class="col-md-3">
                <div class="sidebar-user-info d-flex align-items-center mb-4">
                    <img src="https://ui-avatars.com/api/?name=@User.Identity?.Name&background=3b5d50&color=fff" alt="Avatar" class="sidebar-avatar me-3" />
                    <div>
                        <h6 class="mb-0 fw-bold">@User.Identity?.Name</h6>
                        <a href="#" class="text-muted small text-decoration-none edit-profile-link">
                            <svg viewBox="0 0 24 24" width="16" height="16"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="currentColor" /></svg> Sửa Hồ Sơ
                        </a>
                    </div>
                </div>

                <ul class="sidebar-menu list-unstyled">
                    <li class="menu-item active mb-2">
                        <a href="#">
                            <svg viewBox="0 0 24 24" class="menu-icon text-primary" width="20" height="20"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor" /></svg> Tài Khoản Của Tôi
                        </a>
                        <ul class="sub-menu list-unstyled ms-4 mt-2">
                            <li><a asp-controller="Account" asp-action="Profile">Hồ Sơ</a></li>
                            <li><a asp-controller="Account" asp-action="Bank">Ngân Hàng</a></li>
                            <li><a asp-controller="Account" asp-action="Address">Địa Chỉ</a></li>
                            <li><a asp-controller="Account" asp-action="ChangePassword" class="active-text">Đổi Mật Khẩu</a></li>
                        </ul>
                    </li>
                    <li class="menu-item mb-2 mt-3">
                        <a asp-controller="Order" asp-action="History" class="text-decoration-none text-dark">
                            <svg viewBox="0 0 24 24" class="menu-icon text-info"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" fill="currentColor" /></svg> Đơn Mua
                        </a>
                    </li>
                </ul>
            </div>

            <div class="col-md-9">
                <div class="profile-card card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom pt-4 pb-3 px-4">
                        <h5 class="mb-1 fw-bold">Đổi Mật Khẩu</h5>
                        <p class="text-muted small mb-0">Để bảo mật tài khoản, vui lòng không chia sẻ mật khẩu cho người khác.</p>
                    </div>

                    <div class="card-body p-4">
                        <form asp-controller="Account" asp-action="ChangePassword" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                            <div class="row mb-4">
                                <div class="col-md-3 text-md-end pt-2">
                                    <label asp-for="CurrentPassword" class="form-label-custom">Mật khẩu hiện tại</label>
                                </div>
                                <div class="col-md-8">
                                    <input asp-for="CurrentPassword" class="form-control form-control-custom" placeholder="Nhập mật khẩu hiện tại..." />
                                    <span asp-validation-for="CurrentPassword" class="text-error-custom"></span>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-3 text-md-end pt-2">
                                    <label asp-for="NewPassword" class="form-label-custom">Mật khẩu mới</label>
                                </div>
                                <div class="col-md-8">
                                    <input asp-for="NewPassword" class="form-control form-control-custom" placeholder="Nhập mật khẩu mới (ít nhất 6 ký tự)..." />
                                    <span asp-validation-for="NewPassword" class="text-error-custom"></span>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-3 text-md-end pt-2">
                                    <label asp-for="ConfirmPassword" class="form-label-custom">Xác nhận mật khẩu</label>
                                </div>
                                <div class="col-md-8">
                                    <input asp-for="ConfirmPassword" class="form-control form-control-custom" placeholder="Nhập lại mật khẩu mới..." />
                                    <span asp-validation-for="ConfirmPassword" class="text-error-custom"></span>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-3"></div>
                                <div class="col-md-8">
                                    <button type="submit" class="btn-green-custom">Lưu thay đổi</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}