@model ASPtestShop.Models.ViewModels.Auth.AdminLoginViewModel

@{
    ViewData["Title"] = "Admin Login - HShop";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - HShop</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/Style.css" />
</head>
<body class="admin-login-body">

    <div class="admin-login-wrapper login-container">
        <div class="card border-0 admin-login-card">

            <div class="card-header admin-login-header">
                <h4 class="fw-bold mb-1 text-white">HShop Admin</h4>
                <p class="mb-0 small text-white-50">Đăng nhập quản trị</p>
            </div>

            <div class="card-body p-4 p-md-5">
                <form action="/admin/login" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="EmailOrUserName" class="form-label">
                            Email hoặc Username
                        </label>
                        <input asp-for="EmailOrUserName"
                               class="form-control"
                               placeholder="Nhập email hoặc username admin" />
                        <span asp-validation-for="EmailOrUserName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label">
                            Mật khẩu
                        </label>
                        <input asp-for="Password"
                               class="form-control"
                               placeholder="Nhập mật khẩu" />
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-check mb-4 d-flex align-items-center">
                        <input asp-for="RememberMe" class="form-check-input me-2 mt-0 admin-login-checkbox" id="rememberAdmin" />
                        <label asp-for="RememberMe" class="form-check-label mb-0 admin-login-check-label" for="rememberAdmin">
                            Ghi nhớ đăng nhập
                        </label>
                    </div>

                    <button type="submit" class="btn login-btn w-100 mt-2">
                        ĐĂNG NHẬP
                    </button>
                </form>
            </div>

        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>