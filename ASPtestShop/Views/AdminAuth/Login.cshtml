@model ASPtestShop.Models.ViewModels.Auth.AdminLoginViewModel

@{
    ViewData["Title"] = "Admin Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - HShop</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            body {
                min-height: 100vh;
                background: #f3f4f6;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-card {
                width: 100%;
                max-width: 460px;
            }

            .login-title {
                font-weight: 700;
            }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="card shadow border-0">
            <div class="card-header bg-dark text-white text-center py-3">
                <h4 class="mb-0 login-title">HShop Admin</h4>
                <small>Đăng nhập quản trị</small>
            </div>

            <div class="card-body p-4">
                <form action="/admin/login" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="EmailOrUserName" class="form-label">
                            Email hoặc Username
                        </label>
                        <input asp-for="EmailOrUserName"
                               class="form-control"
                               placeholder="Nhập email hoặc username admin" />
                        <span asp-validation-for="EmailOrUserName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">
                            Mật khẩu
                        </label>
                        <input asp-for="Password"
                               class="form-control"
                               placeholder="Nhập mật khẩu" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">
                            Ghi nhớ đăng nhập
                        </label>
                    </div>

                    <button type="submit" class="btn btn-dark w-100">
                        Đăng nhập
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>