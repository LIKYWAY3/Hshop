@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý đơn hàng</h2>

        <a href="/admin" class="btn btn-outline-dark">
            Quay lại Admin
        </a>
    </div>

    <div id="orderMessage"></div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Người nhận</th>
                            <th>SĐT</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái đơn</th>
                            <th>Thanh toán</th>
                            <th>Phương thức</th>
                            <th>Ngày đặt</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody id="orderTableBody">
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                Đang tải đơn hàng...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    const orderTableBody = document.getElementById("orderTableBody");
    const orderMessage = document.getElementById("orderMessage");

    document.addEventListener("DOMContentLoaded", function() {
        loadAdminOrders();
    });

    async function loadAdminOrders() {
        try {
            const response = await fetch("/api/admin/orders", {
                method: "GET",
                credentials: "include"
            });

            if (response.status === 401 || response.status === 403) {
                window.location.href = "/admin/login";
                return;
            }

            if (!response.ok) {
                orderMessage.innerHTML = `
                        <div class="alert alert-danger">
                            Không thể tải danh sách đơn hàng.
                        </div>
                    `;
                orderTableBody.innerHTML = "";
                return;
            }

            const orders = await response.json();

            renderOrders(orders);

        } catch (error) {
            console.error("Lỗi tải admin orders:", error);

            orderMessage.innerHTML = `
                    <div class="alert alert-danger">
                        Có lỗi xảy ra khi tải đơn hàng.
                    </div>
                `;

            orderTableBody.innerHTML = "";
        }
    }

    function renderOrders(orders) {
        if (!Array.isArray(orders) || orders.length === 0) {
            orderTableBody.innerHTML = `
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            Chưa có đơn hàng nào.
                        </td>
                    </tr>
                `;
            return;
        }

        orderTableBody.innerHTML = "";

        orders.forEach(order => {
            orderTableBody.innerHTML += `
                    <tr>
                        <td>
                            <strong>${order.orderCode || ""}</strong>
                        </td>

                        <td>${order.receiverName || ""}</td>

                        <td>${order.receiverPhone || ""}</td>

                        <td>
                            <strong>${formatCurrency(order.finalAmount)}</strong>
                        </td>

                        <td>
                            ${renderOrderStatus(order.orderStatus)}
                        </td>

                        <td>
                            ${renderPaymentStatus(order.paymentStatus)}
                        </td>

                        <td>${order.paymentMethod || "COD"}</td>

                        <td>${formatDate(order.createdAt)}</td>

                        <td class="text-end">
                            <a href="/admin/orders/detail/${order.orderId}" class="btn btn-sm btn-dark">
                                Chi tiết
                            </a>
                        </td>
                    </tr>
                `;
        });
    }

    function formatCurrency(value) {
        return new Intl.NumberFormat("vi-VN", {
            style: "currency",
            currency: "VND"
        }).format(value || 0);
    }

    function formatDate(value) {
        if (!value) return "";

        const date = new Date(value);

        return date.toLocaleDateString("vi-VN") + " " + date.toLocaleTimeString("vi-VN", {
            hour: "2-digit",
            minute: "2-digit"
        });
    }

    function renderOrderStatus(status) {
        const value = status || "Pending";

        let badgeClass = "bg-secondary";

        if (value === "Pending") badgeClass = "bg-warning text-dark";
        if (value === "Confirmed") badgeClass = "bg-primary";
        if (value === "Shipped") badgeClass = "bg-info text-dark";
        if (value === "Completed") badgeClass = "bg-success";
        if (value === "Cancelled") badgeClass = "bg-danger";

        return `<span class="badge ${badgeClass}">${value}</span>`;
    }

    function renderPaymentStatus(status) {
        const value = status || "Unpaid";

        let badgeClass = "bg-secondary";

        if (value === "Unpaid") badgeClass = "bg-warning text-dark";
        if (value === "Paid") badgeClass = "bg-success";
        if (value === "Failed") badgeClass = "bg-danger";

        return `<span class="badge ${badgeClass}">${value}</span>`;
    }
</script>