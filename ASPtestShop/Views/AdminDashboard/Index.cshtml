@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <h2 class="mb-4">Admin Dashboard</h2>

    <div class="row g-4">
        <div class="col-md-4">
            <a href="/admin/products" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">Quản lý sản phẩm</h5>
                        <p class="card-text text-muted">
                            Thêm, sửa, ẩn, restore sản phẩm và upload ảnh.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/admin/categories" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">Quản lý danh mục</h5>
                        <p class="card-text text-muted">
                            Thêm, sửa, ẩn, restore danh mục sản phẩm.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/admin/orders" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">Quản lý đơn hàng</h5>
                        <p class="card-text text-muted">
                            Quản lí các đơn hàng, tình trạng.
                        </p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>