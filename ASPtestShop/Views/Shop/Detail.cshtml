@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = "~/Views/Shared/_LayoutCustomer.cshtml";
}

<div class="container my-5">

    <!-- Loading -->
    <div id="product-loading"
         class="d-flex justify-content-center align-items-center py-5">

        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>

        <h4 class="text-muted ms-3 mb-0">
            Đang tải thông tin sản phẩm...
        </h4>
    </div>

    <!-- Thông báo lỗi -->
    <div id="product-error"
         class="alert alert-danger text-center py-4 d-none">

        <h4>Không thể hiển thị sản phẩm</h4>

        <p id="product-error-message" class="mb-3"></p>

        <a asp-controller="Shop"
           asp-action="Index"
           class="btn btn-dark">
            Quay lại Shop
        </a>
    </div>

    <!-- Nội dung sản phẩm -->
    <div id="product-content" class="row g-5 d-none">

        <!-- Ảnh sản phẩm -->
        <div class="col-lg-6">
            <div class="product-image-wrapper shadow-sm">

                <img id="product-image"
                     src="/images/no-image.png"
                     alt="Ảnh sản phẩm"
                     class="img-fluid product-detail-image">

            </div>
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-lg-6">

            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home"
                           asp-action="Index"
                           class="text-decoration-none">
                            Trang chủ
                        </a>
                    </li>

                    <li class="breadcrumb-item">
                        <a asp-controller="Shop"
                           asp-action="Index"
                           class="text-decoration-none">
                            Shop
                        </a>
                    </li>

                    <li id="breadcrumb-product-name"
                        class="breadcrumb-item active"
                        aria-current="page">
                        Chi tiết sản phẩm
                    </li>
                </ol>
            </nav>

            <h1 id="product-name"
                class="display-6 fw-bold product-detail-name">
            </h1>

            <div class="mt-3">
                <span id="product-price"
                      class="product-detail-price">
                </span>

                <span id="product-original-price"
                      class="product-original-price d-none">
                </span>
            </div>

            <div class="mt-3">
                <span class="fw-semibold">Tình trạng:</span>

                <span id="product-stock-status"
                      class="badge ms-2">
                </span>
            </div>

            <div class="mt-4">
                <h5 class="fw-bold">Mô tả sản phẩm</h5>

                <p id="product-description"
                   class="text-muted product-description">
                </p>
            </div>

            <div id="cart-message" class="mt-3"></div>

            <div class="d-flex flex-wrap align-items-center gap-3 mt-4">

                <label for="quantity"
                       class="fw-bold mb-0">
                    Số lượng:
                </label>

                <div class="detail-qty-ctrl">

                    <button type="button"
                            id="btn-decrease"
                            class="detail-qty-btn"
                            aria-label="Giảm số lượng">
                        −
                    </button>

                    <input type="number"
                           id="quantity"
                           class="detail-qty-input"
                           value="1"
                           min="1"
                           max="99"
                           aria-label="Số lượng">

                    <button type="button"
                            id="btn-increase"
                            class="detail-qty-btn"
                            aria-label="Tăng số lượng">
                        +
                    </button>

                </div>

                <button type="button"
                        id="btn-add-to-cart"
                        class="btn btn-add-cart btn-lg">

                    <i class="fas fa-shopping-cart me-2"></i>
                    Thêm vào giỏ

                </button>
            </div>

        </div>
    </div>
</div>

<style>
    .product-image-wrapper {
        padding: 24px;
        background-color: #ffffff;
        border-radius: 14px;
        min-height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-detail-image {
        width: 100%;
        max-height: 500px;
        object-fit: contain;
    }

    .product-detail-name {
        color: #253f36;
    }

    .product-detail-price {
        color: #dc3545;
        font-size: 30px;
        font-weight: 700;
    }

    .product-original-price {
        margin-left: 12px;
        color: #888888;
        font-size: 18px;
        text-decoration: line-through;
    }

    .product-description {
        line-height: 1.8;
        white-space: pre-line;
    }

    /* ==============================================
       Nút tăng / giảm số lượng — kiểu bo tròn
    ============================================== */
    .detail-qty-ctrl {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Nút tròn − / + */
    .detail-qty-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 2px solid #3b5d50;
        background-color: #ffffff;
        color: #3b5d50;
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background-color 0.2s, color 0.2s;
        flex-shrink: 0;
        padding: 0;
        user-select: none;
    }

        .detail-qty-btn:hover:not(:disabled) {
            background-color: #3b5d50;
            color: #ffffff;
        }

        .detail-qty-btn:active:not(:disabled) {
            background-color: #2a4338;
            border-color: #2a4338;
            color: #ffffff;
        }

        .detail-qty-btn:disabled {
            opacity: 0.35;
            cursor: not-allowed;
            pointer-events: none;
        }

    /* Input số lượng */
    .detail-qty-input {
        width: 68px;
        height: 40px;
        text-align: center;
        border: 1px solid #ced4da;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        color: #253f36;
        background-color: #fff;
        /* Ẩn mũi tên spin */
        -moz-appearance: textfield;
    }

        .detail-qty-input::-webkit-outer-spin-button,
        .detail-qty-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .detail-qty-input:focus {
            outline: none;
            border-color: #3b5d50;
            box-shadow: 0 0 0 2px rgba(59,93,80,.15);
        }

        .detail-qty-input:disabled {
            background-color: #f5f5f5;
            color: #999;
        }

    /* Nút Thêm vào giỏ */
    .btn-add-cart {
        color: #ffffff;
        background-color: #3b5d50;
        border-color: #3b5d50;
        border-radius: 50px;
        padding: 10px 28px;
        font-weight: 600;
    }

        .btn-add-cart:hover,
        .btn-add-cart:focus {
            color: #000000;
            background-color: #f9bf29;
            border-color: #f9bf29;
        }

        .btn-add-cart:disabled {
            color: #ffffff;
            background-color: #6c757d;
            border-color: #6c757d;
        }
</style>

@section Scripts {
    <script>
        const productId =
            Number.parseInt('@ViewBag.ProductId', 10) || 0;

        let currentProduct = null;

        document.addEventListener(
            "DOMContentLoaded",
            async function() {

                initializeEvents();
                await loadProductDetail();
            }
        );

        function initializeEvents() {
            document
                .getElementById("btn-add-to-cart")
                .addEventListener("click", addToCart);

            document
                .getElementById("btn-increase")
                .addEventListener("click", increaseQuantity);

            document
                .getElementById("btn-decrease")
                .addEventListener("click", decreaseQuantity);

            document
                .getElementById("quantity")
                .addEventListener("change", normalizeQuantity);
        }

        // =============================================
        // LOAD CHI TIẾT SẢN PHẨM
        // =============================================

        async function loadProductDetail() {
            if (productId <= 0) {
                showProductError("ID sản phẩm không hợp lệ.");
                return;
            }

            try {
                const response = await fetch(
                    `/api/products/${productId}`,
                    {
                        method: "GET",
                        credentials: "include",
                        headers: {
                            "Accept": "application/json"
                        }
                    }
                );

                const result = await readJsonResponse(response);

                if (!response.ok) {
                    throw new Error(
                        result?.message
                        ?? result?.error
                        ?? "Không tìm thấy sản phẩm."
                    );
                }

                currentProduct = result?.data ?? result;

                if (!currentProduct) {
                    throw new Error(
                        "Dữ liệu sản phẩm không hợp lệ."
                    );
                }

                renderProduct(currentProduct);
            }
            catch (error) {
                console.error(
                    "Load product detail error:",
                    error
                );

                showProductError(
                    error?.message
                    ?? "Không thể tải thông tin sản phẩm."
                );
            }
        }

        // =============================================
        // HIỂN THỊ SẢN PHẨM
        // =============================================

        function renderProduct(product) {
            const currentProductId = Number(
                product.productId
                ?? product.id
                ?? productId
            );

            if (!Number.isInteger(currentProductId)
                || currentProductId <= 0) {

                showProductError(
                    "Không xác định được sản phẩm."
                );

                return;
            }

            const productName =
                product.productName
                ?? product.name
                ?? "Sản phẩm";

            const description =
                product.description
                ?? product.shortDescription
                ?? "Sản phẩm chưa có mô tả.";

            const price = Number(
                product.price
                ?? product.salePrice
                ?? 0
            );

            const originalPrice = Number(
                product.originalPrice
                ?? product.price
                ?? 0
            );

            const stockQuantity = Number(
                product.stockQuantity ?? 0
            );

            const imageUrl =
                product.thumbnailUrl
                ?? product.imageUrl
                ?? product.images?.[0]?.imageUrl
                ?? product.images?.[0]
                ?? "/images/no-image.png";

            document.getElementById(
                "product-name"
            ).textContent = productName;

            document.getElementById(
                "breadcrumb-product-name"
            ).textContent = productName;

            document.getElementById(
                "product-description"
            ).textContent = description;

            document.getElementById(
                "product-price"
            ).textContent = formatCurrency(price);

            renderOriginalPrice(
                originalPrice,
                price
            );

            renderProductImage(
                imageUrl,
                productName
            );

            renderStockStatus(stockQuantity);

            document.getElementById(
                "product-loading"
            ).classList.add("d-none");

            document.getElementById(
                "product-content"
            ).classList.remove("d-none");
        }

        function renderOriginalPrice(
            originalPrice,
            salePrice
        ) {
            const originalPriceElement =
                document.getElementById(
                    "product-original-price"
                );

            if (originalPrice > salePrice) {
                originalPriceElement.textContent =
                    formatCurrency(originalPrice);

                originalPriceElement.classList.remove(
                    "d-none"
                );

                return;
            }

            originalPriceElement.classList.add(
                "d-none"
            );
        }

        function renderProductImage(
            imageUrl,
            productName
        ) {
            const image =
                document.getElementById(
                    "product-image"
                );

            image.src = imageUrl;
            image.alt = productName;

            image.onerror = function() {
                this.onerror = null;
                this.src = "/images/no-image.png";
            };
        }

        function renderStockStatus(stockQuantity) {
            const stockElement =
                document.getElementById(
                    "product-stock-status"
                );

            const quantityInput =
                document.getElementById("quantity");

            const addButton =
                document.getElementById(
                    "btn-add-to-cart"
                );

            if (stockQuantity > 0) {
                stockElement.textContent =
                    `Còn ${stockQuantity} sản phẩm`;

                stockElement.className =
                    "badge bg-success ms-2";

                quantityInput.max =
                    Math.min(stockQuantity, 99);

                addButton.disabled = false;
                return;
            }

            stockElement.textContent = "Hết hàng";
            stockElement.className =
                "badge bg-danger ms-2";

            quantityInput.value = 1;
            quantityInput.disabled = true;
            document.getElementById("btn-increase").disabled = true;
            document.getElementById("btn-decrease").disabled = true;
            addButton.disabled = true;

            addButton.innerHTML = `
                        <i class="fas fa-ban me-2"></i>
                        Hết hàng
                    `;
        }

        // =============================================
        // QUẢN LÝ SỐ LƯỢNG
        // =============================================

        function increaseQuantity() {
            const input =
                document.getElementById("quantity");

            const currentValue =
                normalizeQuantity();

            const maxValue =
                Number.parseInt(input.max, 10) || 99;

            if (currentValue < maxValue) {
                input.value = currentValue + 1;
            }
        }

        function decreaseQuantity() {
            const input =
                document.getElementById("quantity");

            const currentValue =
                normalizeQuantity();

            if (currentValue > 1) {
                input.value = currentValue - 1;
            }
        }

        function normalizeQuantity() {
            const input =
                document.getElementById("quantity");

            let quantity =
                Number.parseInt(input.value, 10);

            const maxQuantity =
                Number.parseInt(input.max, 10) || 99;

            if (!Number.isInteger(quantity)
                || quantity < 1) {
                quantity = 1;
            }

            if (quantity > maxQuantity) {
                quantity = maxQuantity;
            }

            input.value = quantity;

            return quantity;
        }

        // =============================================
        // THÊM VÀO GIỎ HÀNG
        // =============================================

        async function addToCart() {
            clearCartMessage();

            if (!currentProduct) {
                showCartMessage(
                    "Thông tin sản phẩm chưa được tải.",
                    "danger"
                );

                return;
            }

            const currentProductId = Number(
                currentProduct.productId
                ?? currentProduct.id
                ?? productId
            );

            const quantity = normalizeQuantity();

            if (!Number.isInteger(currentProductId)
                || currentProductId <= 0) {

                showCartMessage(
                    "Không xác định được sản phẩm.",
                    "danger"
                );

                return;
            }

            setAddButtonLoading(true);

            try {
                const response = await fetch(
                    "/api/cart/add",
                    {
                        method: "POST",
                        credentials: "include",
                        headers: {
                            "Content-Type":
                                "application/json",

                            "Accept":
                                "application/json"
                        },
                        body: JSON.stringify({
                            productId: currentProductId,
                            quantity: quantity
                        })
                    }
                );

                if (response.status === 401) {
                    const returnUrl =
                        encodeURIComponent(
                            window.location.pathname
                            + window.location.search
                        );

                    window.location.href =
                        `/account/login?returnUrl=${returnUrl}`;

                    return;
                }

                const result =
                    await readJsonResponse(response);

                if (!response.ok) {
                    throw new Error(
                        result?.message
                        ?? result?.error
                        ?? result?.title
                        ?? "Không thể thêm sản phẩm vào giỏ hàng."
                    );
                }

                showCartMessage(
                    result?.message
                    ?? "Đã thêm sản phẩm vào giỏ hàng.",
                    "success",
                    true
                );

                updateCartCount(result);
            }
            catch (error) {
                console.error(
                    "Add to cart error:",
                    error
                );

                showCartMessage(
                    error?.message
                    ?? "Không thể kết nối đến hệ thống giỏ hàng.",
                    "danger"
                );
            }
            finally {
                setAddButtonLoading(false);
            }
        }

        function setAddButtonLoading(isLoading) {
            const button =
                document.getElementById(
                    "btn-add-to-cart"
                );

            if (!button
                || Number(currentProduct?.stockQuantity) <= 0) {
                return;
            }

            button.disabled = isLoading;

            button.innerHTML = isLoading
                ? `
                            <span class="spinner-border
                                         spinner-border-sm
                                         me-2"
                                  role="status">
                            </span>
                            Đang thêm...
                          `
                : `
                            <i class="fas fa-shopping-cart me-2"></i>
                            Thêm vào giỏ
                          `;
        }

        function updateCartCount(result) {
            const cartCountElement =
                document.getElementById(
                    "cart-count"
                );

            if (!cartCountElement) {
                return;
            }

            const cartCount =
                result?.cartItemCount
                ?? result?.totalQuantity
                ?? result?.data?.cartItemCount
                ?? result?.data?.totalQuantity;

            if (cartCount !== undefined
                && cartCount !== null) {

                cartCountElement.textContent =
                    cartCount;
            }
        }

        // =============================================
        // THÔNG BÁO
        // =============================================

        function showCartMessage(
            message,
            type,
            showCartLink = false
        ) {
            const messageContainer =
                document.getElementById(
                    "cart-message"
                );

            messageContainer.innerHTML = "";

            const alertElement =
                document.createElement("div");

            alertElement.className =
                `alert alert-${type}
                         alert-dismissible fade show`;

            alertElement.setAttribute(
                "role",
                "alert"
            );

            const messageElement =
                document.createElement("span");

            messageElement.textContent = message;

            alertElement.appendChild(
                messageElement
            );

            if (showCartLink) {
                const cartLink =
                    document.createElement("a");

                cartLink.href = "/Cart";
                cartLink.className =
                    "alert-link ms-2";

                cartLink.textContent =
                    "Xem giỏ hàng";

                alertElement.appendChild(
                    cartLink
                );
            }

            const closeButton =
                document.createElement("button");

            closeButton.type = "button";
            closeButton.className = "btn-close";

            closeButton.setAttribute(
                "data-bs-dismiss",
                "alert"
            );

            closeButton.setAttribute(
                "aria-label",
                "Đóng"
            );

            alertElement.appendChild(
                closeButton
            );

            messageContainer.appendChild(
                alertElement
            );
        }

        function clearCartMessage() {
            document.getElementById(
                "cart-message"
            ).innerHTML = "";
        }

        function showProductError(message) {
            document.getElementById(
                "product-loading"
            ).classList.add("d-none");

            document.getElementById(
                "product-content"
            ).classList.add("d-none");

            document.getElementById(
                "product-error-message"
            ).textContent = message;

            document.getElementById(
                "product-error"
            ).classList.remove("d-none");
        }

        // =============================================
        // HELPERS
        // =============================================

        async function readJsonResponse(response) {
            const contentType =
                response.headers.get(
                    "content-type"
                ) ?? "";

            if (!contentType.includes(
                "application/json"
            )) {
                return null;
            }

            try {
                return await response.json();
            }
            catch {
                return null;
            }
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat(
                "vi-VN",
                {
                    style: "currency",
                    currency: "VND"
                }
            ).format(Number(value) || 0);
        }
    </script>
}